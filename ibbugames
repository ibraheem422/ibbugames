        // Star physics properties
        let starX = canvas.width / 2;
        let starY = canvas.height / 2;
        
        const normalRadius = 20;   
        const giantRadius = 40;    
        let currentRadius = normalRadius; 

        // Speeds
        let baseSpeedX = 0;
        let baseSpeedY = 0;
        let speedX = 0;
        let speedY = 0;
        let speedMultiplier = 1; 

        function drawStar(cx, cy, spikes, outerRadius, innerRadius) {
            let rot = Math.PI / 2 * 3;
            let x = cx;
            let y = cy;
            let step = Math.PI / spikes;

            ctx.beginPath();
            ctx.moveTo(cx, cy - outerRadius);
            
            for (let i = 0; i < spikes; i++) {
                x = cx + Math.cos(rot) * outerRadius;
                y = cy + Math.sin(rot) * outerRadius;
                ctx.lineTo(x, y);
                rot += step;

                x = cx + Math.cos(rot) * innerRadius;
                y = cy + Math.sin(rot) * innerRadius;
                ctx.lineTo(x, y);
                rot += step;
            }
            
            ctx.lineTo(cx, cy - outerRadius);
            ctx.closePath();
            ctx.fillStyle = "#FFD700"; 
            ctx.fill();
            ctx.strokeStyle = "#FFA500"; 
            ctx.lineWidth = 3;
            ctx.stroke();
        }

        function updateGame() {
            if (!gameActive) return;

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            starX += speedX;
            starY += speedY;

            // Boundary collision checks
            if (starX - currentRadius < 0 || starX + currentRadius > canvas.width) {
                speedX = -speedX; 
            }
            if (starY - currentRadius < 0 || starY + currentRadius > canvas.height) {
                speedY = -speedY; 
            }

            drawStar(starX, starY, 5, currentRadius, currentRadius / 2);

            animationId = requestAnimationFrame(updateGame);
        }

        function updateSpeedForLevel() {
            const levelIncreases = level - 1;
            speedX = speedX > 0 ? baseSpeedX + (levelIncreases * speedMultiplier) : -baseSpeedX - (levelIncreases * speedMultiplier);
            speedY = speedY > 0 ? baseSpeedY + (levelIncreases * speedMultiplier) : -baseSpeedY - (levelIncreases * speedMultiplier);
        }

        // Timer Helper Function (MM:SS format)
        function updateTimerDisplay() {
            const minutes = Math.floor(gameSeconds / 60);
            const seconds = gameSeconds % 60;
            const formattedMinutes = minutes < 10 ? "0" + minutes : minutes;
            const formattedSeconds = seconds < 10 ? "0" + seconds : seconds;
            timerText.textContent = `${formattedMinutes}:${formattedSeconds}`;
        }

        function startTimer() {
            stopTimer(); // Ensure we don't have multiple timers running
            gameSeconds = 0;
            updateTimerDisplay();
            timerInterval = setInterval(() => {
                gameSeconds++;
                updateTimerDisplay();
            }, 1000);
        }

        function stopTimer() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
        }

        // Interactive Panel Toggles
        settingsBtn.addEventListener("click", function() {
            mainMenuPanel.style.display = "none";
            settingsPanel.style.display = "block";
        });

        backBtn.addEventListener("click", function() {
            settingsPanel.style.display = "none";
            mainMenuPanel.style.display = "block";
        });

        // Start button trigger logic
        startBtn.addEventListener("click", function() {
            const difficulty = difficultySelect.value;

            if (difficulty === "easy") {
                baseSpeedX = 2; baseSpeedY = 1.5; speedMultiplier = 0.5;
            } else if (difficulty === "medium") {
                baseSpeedX = 4; baseSpeedY = 3; speedMultiplier = 1;
            } else if (difficulty === "hard") {
                baseSpeedX = 7; baseSpeedY = 5; speedMultiplier = 1.5;
            }

            speedX = baseSpeedX;
            speedY = baseSpeedY;
            score = 0;
            level = 1;
            scoreText.textContent = score;
            levelText.textContent = level;

            // --- STREAK VALIDATION ENGINE ---
            const todayDateString = new Date().toDateString(); 
            const streakKey = isGuest ? "starCollectorStreak_guest" : `starCollectorStreak_${currentPilot.toLowerCase()}`;
            const lastPlayedKey = isGuest ? "starCollectorLastDate_guest" : `starCollectorLastDate_${currentPilot.toLowerCase()}`;
            const lastPlayedDate = storage.getItem(lastPlayedKey);

            if (lastPlayedDate !== todayDateString) {
                playStreak++;
                streakText.textContent = playStreak;
                storage.setItem(streakKey, playStreak);
                storage.setItem(lastPlayedKey, todayDateString);
            }

            // Centralized reset parameters
            starX = canvas.width / 2;
            starY = canvas.height / 2;
            currentRadius = normalRadius;

            // Screen layout state switches
            menu.style.display = "none";
            statsDiv.style.display = "flex";
            canvas.style.display = "block";
            controlsDiv.style.display = "block";

            // Start Live Timer
            startTimer();

            gameActive = true;
            updateGame();
        });

        // Event listener for canvas click detection
        canvas.addEventListener("click", function(event) {
            if (!gameActive) return;

            const rect = canvas.getBoundingClientRect();
            const mouseX = (event.clientX - rect.left) * (canvas.width / rect.width);
            const mouseY = (event.clientY - rect.top) * (canvas.height / rect.height);

            const distance = Math.sqrt((mouseX - starX) ** 2 + (mouseY - starY) ** 2);

            if (distance < currentRadius) {
                score++;
                scoreText.textContent = score;

                // High score logic integration per active user session
                if (score > highScore) {
                    highScore = score;
                    highScoreText.textContent = highScore;
                    const scoreKey = isGuest ? "starCollectorHighScore_guest" : `starCollectorHighScore_${currentPilot.toLowerCase()}`;
                    storage.setItem(scoreKey, highScore);
                }

                currentRadius = giantRadius;
                setTimeout(function() {
                    currentRadius = normalRadius;
                }, 2000);

                if (score % 5 === 0) {
                    level++;
                    levelText.textContent = level;
                    updateSpeedForLevel();
                }
            }
        });

        resetScoreBtn.addEventListener("click", function() {
            score = 0;
            scoreText.textContent = score;
        });

        resetLevelBtn.addEventListener("click", function() {
            level = 1;
            levelText.textContent = level;
            updateSpeedForLevel();
        });

        resetBothBtn.addEventListener("click", function() {
            score = 0;
            level = 1;
            scoreText.textContent = score;
            levelText.textContent = level;
            updateSpeedForLevel();
        });

        endGameBtn.addEventListener("click", function() {
            gameActive = false;
            cancelAnimationFrame(animationId);
            
            // Turn off timer
            stopTimer();

            statsDiv.style.display = "none";
            canvas.style.display = "none";
            controlsDiv.style.display = "none";
            menu.style.display = "block";
            
            // Clean view return
            settingsPanel.style.display = "none";
            adminNotificationsPanel.style.display = "none";
            mainMenuPanel.style.display = "block";
        });
    </script>

</body>
</html>
