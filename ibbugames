<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Star Collector</title>
    <!-- URL-Encoded SVG Favicon to ensure the golden star emoji displays in the browser tab -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' font-size='90'%3E⭐%3C/text%3E%3C/svg%3E">
    <style>
        /* Base theme CSS variables - default is Dark Mode */
        :root {
            --bg-color: #111424;
            --text-color: #ffffff;
            --panel-bg: #1b1f38;
            --border-color: #4a55a2;
            --select-bg: #4a55a2;
            --select-border: #5c6bc0;
            --select-text: #ffffff;
            --label-color: #b3b9df;
        }

        /* Light Mode theme adjustments override */
        [data-theme="light"] {
            --bg-color: #f0f2f9;
            --text-color: #111424;
            --panel-bg: #ffffff;
            --border-color: #4a55a2;
            --select-bg: #ffffff;
            --select-border: #4a55a2;
            --select-text: #111424;
            --label-color: #4a55a2;
        }

        /* Base page styling using theme variables */
        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            text-align: center;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
            box-sizing: border-box;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Container to ensure a clean vertical layout flow */
        .wrapper {
            width: 100%;
            max-width: 600px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Style for the website logo and its fallback container */
        .logo-container {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 10px auto 10px auto;
            min-height: 80px;
        }
        .site-logo {
            max-width: 120px;
            height: auto;
            display: block;
        }
        /* Stylish modern backup logo if logo.png is missing */
        .fallback-logo {
            background: linear-gradient(135deg, #FFD700, #FFA500);
            width: 70px;
            height: 70px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.4);
            animation: pulse 2s infinite alternate;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            100% { transform: scale(1.08); }
        }

        h1 {
            margin: 0 0 15px 0;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--text-color);
            font-size: 36px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        }

        /* Menu layout card using variables */
        #menu {
            background-color: var(--panel-bg);
            border: 4px solid var(--border-color);
            border-radius: 12px;
            width: 100%;
            max-width: 320px;
            margin: 15px auto;
            padding: 25px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            box-sizing: border-box;
            transition: background-color 0.3s, border-color 0.3s;
        }

        .menu-element {
            margin: 15px 0;
            display: flex;
            justify-content: center;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        /* Panel Views */
        #loginPanel {
            display: block;
            width: 100%;
        }

        #mainMenuPanel {
            display: none;
            width: 100%;
        }

        #settingsPanel {
            display: none;
            width: 100%;
        }

        #adminNotificationsPanel {
            display: none;
            width: 100%;
        }

        #guestWaitingPanel {
            display: none;
            width: 100%;
            text-align: center;
        }

        #guestNamePanel {
            display: none;
            width: 100%;
        }

        /* Shared Form Inputs for Login and Register fields */
        input {
            font-size: 16px;
            padding: 10px 14px;
            border-radius: 6px;
            background-color: var(--select-bg);
            color: var(--select-text);
            border: 2px solid var(--select-border);
            outline: none;
            width: 100%;
            box-sizing: border-box;
            transition: all 0.2s;
            margin-bottom: 12px;
        }
        input::placeholder {
            color: var(--label-color);
            opacity: 0.6;
        }
        input:focus {
            border-color: #FFD700;
        }

        .form-label {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 6px;
            color: var(--label-color);
            text-align: left;
            width: 100%;
        }

        /* Styling for Auth tabs (Log In / Sign Up toggles) */
        .auth-tabs {
            display: flex;
            gap: 10px;
            width: 100%;
            margin-bottom: 15px;
        }
        .auth-tab {
            flex: 1;
            font-size: 14px;
            padding: 8px 12px;
            border-radius: 6px;
            background-color: transparent;
            color: var(--label-color);
            border: 1.5px solid var(--border-color);
            cursor: pointer;
            font-weight: bold;
            box-shadow: none;
            transition: all 0.2s;
        }
        .auth-tab:hover {
            border-color: #FFD700;
            color: var(--text-color);
            transform: none;
            box-shadow: none;
        }
        .auth-tab.active {
            background-color: #4a55a2;
            color: white;
            border-color: #4a55a2;
        }

        .auth-message {
            font-size: 13px;
            color: #d9534f;
            margin-bottom: 12px;
            font-weight: bold;
            display: none;
            width: 100%;
            text-align: center;
        }
        .auth-message.success {
            color: #5cb85c;
        }

        .profile-badge {
            font-size: 14px;
            font-weight: bold;
            color: #FFD700;
            background-color: rgba(255, 215, 0, 0.1);
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            width: 100%;
            box-sizing: border-box;
            margin-bottom: 10px;
            text-align: center;
        }

        select {
            font-size: 16px;
            padding: 10px 14px;
            border-radius: 6px;
            background-color: var(--select-bg);
            color: var(--select-text);
            border: 2px solid var(--select-border);
            cursor: pointer;
            outline: none;
            width: 100%;
            box-sizing: border-box;
            transition: all 0.2s;
        }
        select:focus {
            border-color: #FFD700;
        }

        /* Buttons that pop */
        button {
            font-size: 18px;
            padding: 12px 24px;
            border-radius: 6px;
            background-color: #FFD700;
            color: #111424;
            border: none;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 10px rgba(255, 215, 0, 0.2);
            width: 100%;
            box-sizing: border-box;
        }
        button:hover {
            background-color: #FFA500;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(255, 165, 0, 0.4);
        }
        button:active {
            transform: translateY(1px);
        }

        /* Style variation for secondary buttons */
        .secondary-btn {
            background-color: #4a55a2;
            color: white;
            box-shadow: 0 4px 10px rgba(74, 85, 162, 0.2);
        }
        .secondary-btn:hover {
            background-color: #3b4380;
            box-shadow: 0 6px 15px rgba(74, 85, 162, 0.4);
        }

        /* Admin Notifications Styling */
        .admin-badge {
            background-color: #FF6B6B;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            margin-left: 8px;
            font-weight: bold;
        }

        .notification-item {
            background-color: rgba(255, 107, 107, 0.1);
            border-left: 4px solid #FF6B6B;
            padding: 12px;
            margin-bottom: 12px;
            border-radius: 6px;
            border: 1px solid rgba(255, 107, 107, 0.3);
        }

        .notification-item h3 {
            margin: 0 0 8px 0;
            color: #FFD700;
            font-size: 16px;
        }

        .notification-item p {
            margin: 0 0 10px 0;
            color: var(--text-color);
            font-size: 14px;
        }

        .notification-actions {
            display: flex;
            gap: 8px;
            width: 100%;
        }

        .notification-actions button {
            flex: 1;
            font-size: 14px;
            padding: 8px 12px;
            margin: 0;
        }

        .accept-btn {
            background-color: #5cb85c;
        }
        .accept-btn:hover {
            background-color: #4cae4c;
        }

        .decline-btn {
            background-color: #d9534f;
        }
        .decline-btn:hover {
            background-color: #c9302c;
        }

        .no-notifications {
            text-align: center;
            color: #b3b9df;
            padding: 20px;
            font-size: 16px;
        }

        /* Game interface layouts */
        #stats {
            font-size: 18px;
            margin-bottom: 15px;
            display: none;
            width: 100%;
            justify-content: center;
            gap: 10px;
        }
        .stat-box {
            background-color: var(--panel-bg);
            padding: 10px 15px;
            border-radius: 8px;
            border: 2px solid var(--border-color);
            font-weight: bold;
            min-width: 90px;
            color: var(--text-color);
            transition: background-color 0.3s, border-color 0.3s;
            box-sizing: border-box;
        }

        canvas {
            background-color: var(--panel-bg);
            border: 4px solid var(--border-color);
            border-radius: 12px;
            cursor: pointer;
            display: none;
            margin: 0 auto;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
            max-width: 100%;
            height: auto;
            transition: background-color 0.3s, border-color 0.3s;
        }

        /* Controls design */
        #controls {
            display: none;
            margin-top: 15px;
            width: 100%;
            max-width: 500px;
        }
        .control-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 10px;
        }
        .control-btn {
            font-size: 14px;
            padding: 10px 15px;
            background-color: #4a55a2;
            color: white;
            border-radius: 6px;
            box-shadow: none;
            width: 100%;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }
        .control-btn:hover {
            background-color: #3b4380;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }
        #endGameBtn {
            background-color: #d9534f;
            color: white;
            grid-column: span 2;
            font-size: 16px;
            padding: 12px;
        }
        #endGameBtn:hover {
            background-color: #c9302c;
        }

        .menu-stat {
            font-size: 16px;
            color: #FFD700;
            font-weight: bold;
            background-color: rgba(255, 255, 255, 0.05);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
            box-sizing: border-box;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        [data-theme="light"] .menu-stat {
            background-color: rgba(74, 85, 162, 0.05);
            border: 1px solid rgba(74, 85, 162, 0.2);
            color: #4a55a2;
        }

        /* Notification badge animation */
        @keyframes badgePulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.15); }
        }

        .admin-badge.new-notification {
            animation: badgePulse 0.6s ease-in-out infinite;
            background-color: #FF6B6B;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <!-- Logo Section with Smart Fallback -->
        <div class="logo-container">
            <img id="logoImg" src="logo.png" alt="Game Logo" class="site-logo" onerror="handleLogoError()">
        </div>

        <h1>Star Collector</h1>

        <div id="menu">
            <!-- ==================== LOGIN / REGISTRATION SYSTEM ==================== -->
            <div id="loginPanel">
                <div class="auth-tabs">
                    <button id="authLoginTab" class="auth-tab active">Log In</button>
                    <button id="authSignUpTab" class="auth-tab">Sign Up</button>
                </div>

                <div id="authMsg" class="auth-message"></div>

                <form id="authForm" onsubmit="event.preventDefault();">
                    <div id="signupNameField" class="menu-element" style="align-items: flex-start; margin: 0 0 10px 0; display: none;">
                        <label class="form-label" for="authName">Full Name:</label>
                        <input id="authName" type="text" placeholder="Your full name..." required>
                    </div>

                    <div class="menu-element" style="align-items: flex-start; margin: 0 0 10px 0;">
                        <label class="form-label" for="authUsername">Username:</label>
                        <input id="authUsername" type="text" placeholder="Astronaut name..." required>
                    </div>

                    <div class="menu-element" style="align-items: flex-start; margin: 0 0 15px 0;">
                        <label class="form-label" for="authPassword">Password:</label>
                        <input id="authPassword" type="password" placeholder="🔑 Password" required>
                    </div>

                    <div class="menu-element" style="margin: 10px 0;">
                        <button id="authSubmitBtn" type="button">Log In</button>
                    </div>

                    <div class="menu-element" style="margin: 0;">
                        <button id="guestPlayBtn" class="secondary-btn" type="button">🚀 Play as Guest</button>
                    </div>
                </form>
            </div>

            <!-- ==================== ADMIN NOTIFICATIONS PANEL ==================== -->
            <div id="adminNotificationsPanel">
                <h2 style="margin-top: 0; color: #FF6B6B; font-size: 24px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 20px;">👮 Admin Notifications</h2>
                
                <div id="notificationsList"></div>
                
                <div class="menu-element" style="margin-top: 20px;">
                    <button id="backFromAdminBtn" class="secondary-btn">⬅️ Back to Menu</button>
                </div>
            </div>

            <!-- ==================== MAIN MENU VIEW ==================== -->
            <div id="mainMenuPanel">
                <div class="profile-badge">
                    🧑‍🚀 Pilot: <span id="activePilot">Guest</span>
                </div>
                <div class="menu-element">
                    <div class="menu-stat">
                        <span>Daily Streak:</span>
                        <span><span id="streakText">0</span> 🔥</span>
                    </div>
                </div>
                <div class="menu-element">
                    <div class="menu-stat">
                        <span>High Score:</span>
                        <span><span id="highScoreText">0</span> 🏆</span>
                    </div>
                </div>
                <div class="menu-element" id="adminNotificationsBtnContainer" style="display: none;">
                    <button id="adminNotificationsBtn" class="secondary-btn">👮 Admin Notifications <span id="notificationCount" class="admin-badge">0</span></button>
                </div>
                <div class="menu-element" id="adminRefreshBtnContainer" style="display: none;">
                    <button id="adminRefreshBtn" class="secondary-btn" style="background-color: #5cb85c; font-size: 14px; padding: 8px 12px;">🔄 Check for New Requests</button>
                </div>
                <div class="menu-element">
                    <button id="startBtn">Start Game</button>
                </div>
                <div class="menu-element">
                    <button id="settingsBtn" class="secondary-btn">⚙️ Game Settings</button>
                </div>
                <div class="menu-element">
                    <button id="logoutBtn" class="secondary-btn" style="background-color: #d9534f;">🚪 Log Out</button>
                </div>
            </div>

            <!-- ==================== GUEST NAME REQUEST PANEL ==================== -->
            <div id="guestNamePanel">
                <h2 style="margin-top: 20px; color: #FFD700; font-size: 28px; margin-bottom: 20px;">👤 Guest Information</h2>
                
                <div style="background-color: rgba(255, 215, 0, 0.1); border-left: 4px solid #FFD700; padding: 20px; border-radius: 8px; margin-bottom: 25px;">
                    <p style="font-size: 16px; margin: 10px 0; color: var(--text-color);">Welcome to Star Collector!</p>
                    <p style="font-size: 14px; color: var(--label-color); margin: 10px 0;">Please enter your name before requesting guest access.</p>
                </div>

                <form id="guestNameForm" onsubmit="event.preventDefault();">
                    <div class="menu-element" style="align-items: flex-start; margin: 0 0 20px 0;">
                        <label class="form-label" for="guestNameInput">Your Name:</label>
                        <input id="guestNameInput" type="text" placeholder="Enter your name..." required>
                    </div>

                    <div class="menu-element" style="margin: 10px 0;">
                        <button id="guestSendRequestBtn" type="button" class="secondary-btn" style="background-color: #FFD700; color: #111424;">📤 Send Request to Admin</button>
                    </div>

                    <div class="menu-element" style="margin: 0;">
                        <button id="guestBackBtn" type="button" class="secondary-btn" style="background-color: #d9534f;">❌ Back to Login</button>
                    </div>
                </form>
            </div>

            <!-- ==================== GUEST WAITING FOR APPROVAL PANEL ==================== -->
            <div id="guestWaitingPanel">
                <h2 style="margin-top: 20px; color: #FFD700; font-size: 28px; margin-bottom: 20px;">⏳ Awaiting Admin Approval</h2>
                
                <div style="background-color: rgba(255, 215, 0, 0.1); border-left: 4px solid #FFD700; padding: 20px; border-radius: 8px; margin-bottom: 25px;">
                    <p style="font-size: 16px; margin: 10px 0; color: var(--text-color);">Your guest play session has been submitted to the admin for approval.</p>
                    <p style="font-size: 14px; color: var(--label-color); margin: 10px 0;">Please wait while the admin reviews your request...</p>
                </div>

                <div style="margin-bottom: 20px;">
                    <div style="display: inline-block; width: 40px; height: 40px; border: 4px solid #FFD700; border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                    <style>
                        @keyframes spin {
                            0% { transform: rotate(0deg); }
                            100% { transform: rotate(360deg); }
                        }
                    </style>
                </div>

                <p style="font-size: 14px; color: #FFD700; margin-bottom: 25px; font-weight: bold;">Status: <span id="guestApprovalStatus">Pending...</span></p>

                <button id="guestRefreshBtn" class="secondary-btn" style="margin-bottom: 12px;">🔄 Check Status</button>
                <button id="guestCancelBtn" class="secondary-btn" style="background-color: #d9534f;">❌ Cancel Request</button>
            </div>
            <div id="settingsPanel">
                <h2 style="margin-top: 0; color: #FFD700; font-size: 24px; border-bottom: 2px solid var(--border-color); padding-bottom: 8px; margin-bottom: 20px;">Settings</h2>
                
                <div class="menu-element" style="align-items: flex-start; margin-bottom: 15px;">
                    <label for="difficulty" style="font-size: 15px; font-weight: bold; margin-bottom: 6px; color: var(--label-color); text-align: left;">Difficulty Preset:</label>
                    <select id="difficulty">
                        <option value="easy">Easy (Relaxed)</option>
                        <option value="medium" selected>Medium (Standard)</option>
                        <option value="hard">Hard (Extreme)</option>
                    </select>
                </div>

                <div class="menu-element" style="align-items: flex-start; margin-bottom: 15px;">
                    <label for="themeMode" style="font-size: 15px; font-weight: bold; margin-bottom: 6px; color: var(--label-color); text-align: left;">Theme Mode:</label>
                    <select id="themeMode">
                        <option value="dark" selected>Dark Mode (Default)</option>
                        <option value="light">Light Mode</option>
                    </select>
                </div>

                <div class="menu-element" style="margin-top: 25px;">
                    <button id="backBtn" class="secondary-btn">⬅️ Back to Menu</button>
                </div>
            </div>
        </div>

        <!-- ==================== IN-GAME STATS & INTERFACE ==================== -->
        <div id="stats">
            <span class="stat-box">Score: <span id="scoreText">0</span></span>
            <span class="stat-box">Time: <span id="timerText">00:00</span></span>
            <span class="stat-box">Level: <span id="levelText">1</span></span>
        </div>
        
        <canvas id="gameCanvas" width="500" height="400"></canvas>

        <div id="controls">
            <div class="control-grid">
                <button id="resetScoreBtn" class="control-btn">Reset Score</button>
                <button id="resetLevelBtn" class="control-btn">Reset Level</button>
                <button id="resetBothBtn" class="control-btn" style="grid-column: span 2;">Reset Score & Level</button>
            </div>
            <button id="endGameBtn" class="control-btn">End Game</button>
        </div>
    </div>

    <!-- Global App Scripts -->
    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const scoreText = document.getElementById("scoreText");
        const levelText = document.getElementById("levelText");
        const timerText = document.getElementById("timerText");
        const streakText = document.getElementById("streakText");
        const highScoreText = document.getElementById("highScoreText");
        
        const menu = document.getElementById("menu");
        const loginPanel = document.getElementById("loginPanel");
        const mainMenuPanel = document.getElementById("mainMenuPanel");
        const settingsPanel = document.getElementById("settingsPanel");
        const adminNotificationsPanel = document.getElementById("adminNotificationsPanel");
        const guestNamePanel = document.getElementById("guestNamePanel");
        const guestWaitingPanel = document.getElementById("guestWaitingPanel");
        
        const startBtn = document.getElementById("startBtn");
        const settingsBtn = document.getElementById("settingsBtn");
        const backBtn = document.getElementById("backBtn");
        const backFromAdminBtn = document.getElementById("backFromAdminBtn");
        const difficultySelect = document.getElementById("difficulty");
        const themeModeSelect = document.getElementById("themeMode");
        
        const statsDiv = document.getElementById("stats");
        const controlsDiv = document.getElementById("controls");

        const resetScoreBtn = document.getElementById("resetScoreBtn");
        const resetLevelBtn = document.getElementById("resetLevelBtn");
        const resetBothBtn = document.getElementById("resetBothBtn");
        const endGameBtn = document.getElementById("endGameBtn");

        // Auth Dom Elements
        const authLoginTab = document.getElementById("authLoginTab");
        const authSignUpTab = document.getElementById("authSignUpTab");
        const authNameInput = document.getElementById("authName");
        const signupNameField = document.getElementById("signupNameField");
        const authUsernameInput = document.getElementById("authUsername");
        const authPasswordInput = document.getElementById("authPassword");
        const authSubmitBtn = document.getElementById("authSubmitBtn");
        const guestPlayBtn = document.getElementById("guestPlayBtn");
        const logoutBtn = document.getElementById("logoutBtn");
        const activePilotSpan = document.getElementById("activePilot");
        const authMsg = document.getElementById("authMsg");

        // Admin Elements
        const adminNotificationsBtnContainer = document.getElementById("adminNotificationsBtnContainer");
        const adminNotificationsBtn = document.getElementById("adminNotificationsBtn");
        const adminRefreshBtn = document.getElementById("adminRefreshBtn");
        const adminRefreshBtnContainer = document.getElementById("adminRefreshBtnContainer");
        const notificationsList = document.getElementById("notificationsList");
        const notificationCount = document.getElementById("notificationCount");

        // Guest Waiting Elements
        const guestRefreshBtn = document.getElementById("guestRefreshBtn");
        const guestCancelBtn = document.getElementById("guestCancelBtn");
        const guestApprovalStatus = document.getElementById("guestApprovalStatus");

        // Guest Name Elements
        const guestNameInput = document.getElementById("guestNameInput");
        const guestSendRequestBtn = document.getElementById("guestSendRequestBtn");
        const guestBackBtn = document.getElementById("guestBackBtn");

        // Super Admin Credentials
        const SUPER_ADMIN_EMAIL = "ibraheem.muhammad.ai@gmail.com";
        const SUPER_ADMIN_PASSWORD = "Midea@222";

        let score = 0;
        let level = 1;
        let playStreak = 0;
        let highScore = 0;
        let gameActive = false;
        let animationId;
        
